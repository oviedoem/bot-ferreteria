# Variables de entorno para el Bot de Ferreteria
# Copia este archivo a .env y ajusta los valores

# Token de la API de WHAPI (WhatsApp API)
# Obtenlo de https://app.whapi.cloud/settings/api
WHAPI_TOKEN=tu_token_whapi_aqui

# Puerto del servidor (usado por Railway, Render, Heroku)
# No lo cambies: las plataformas usan esta variable
PORT=5000

# Entorno de ejecucion (opcional)
ENVIRONMENT=production
